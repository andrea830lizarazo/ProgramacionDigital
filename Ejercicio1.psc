Algoritmo Ejercicio1
	Definir x Como Entero
	Escribir "Ingrese un numero"
	Leer x
	
	mientras x>0 Hacer
		si x MOD 2 == 0 Entonces
			Escribir "es par"
		SiNo
				Escribir "es impar"
		FinSi
		Imprimir "Ingrese un numero"
		Leer x
	FinMientras
	Imprimir "el numero ingresado fue menor o igual a cero"	
FinAlgoritmo
